# Data — never commit datasets
data/asl_alphabet/
data/asl_alphabet_train/
data/asl_alphabet_test/
data/wlasl/
data/wlasl_landmarks/
# locally-generated missing.txt to upload to the WLASL form
data/wlasl_request/
# Microsoft ASL Citizen dataset (46GB) — never commit
data/asl_citizen/
# ASL Citizen split CSVs (dataset metadata) — don't redistribute
data/asl_citizen_meta/
data/tunsl/
*.zip

# Synthesis sign-video clip dictionary (downloaded/generated, like models)
synthesis/clips/*.mp4
synthesis/clips/*.webm
!synthesis/clips/.gitkeep

# ASR model caches (faster-whisper / huggingface downloads)
.cache/
*.onnx

# Trained artefacts (keep the folder, ignore the weights)
recognition/models/*.keras
recognition/models/*.h5
recognition/models/*.tflite
recognition/models/*_tfjs/
!recognition/models/.gitkeep
sentiment/models/*.pkl
!sentiment/models/.gitkeep

# Results are committed selectively; ignore large caches
recognition/results/cache/

# PyInstaller build output (packaging/groopy.spec) — rebuild locally, don't commit ~2GB
build/
dist/
dist_stdout.log
dist_stderr.log

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# Kaggle credentials
kaggle.json

# OS
.DS_Store
Thumbs.db
data/asl_alphabet_subset/
