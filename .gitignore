# Data — never commit datasets
data/asl_alphabet/
data/asl_alphabet_train/
data/asl_alphabet_test/
data/wlasl/
data/wlasl_landmarks/
data/tunsl/
*.zip

# Synthesis sign-video clip dictionary (downloaded/generated, like models)
synthesis/clips/*.mp4
synthesis/clips/*.webm
!synthesis/clips/.gitkeep

# ASR model caches (faster-whisper / huggingface downloads)
.cache/
*.onnx

# Trained artefacts (keep the folder, ignore the weights)
recognition/models/*.keras
recognition/models/*.h5
recognition/models/*.tflite
recognition/models/*_tfjs/
!recognition/models/.gitkeep

# Results are committed selectively; ignore large caches
recognition/results/cache/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# Kaggle credentials
kaggle.json

# OS
.DS_Store
Thumbs.db
